@model List<Loc.Models.ContactMessage>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p class="lead">Database-backed page (SQLite + EF Core).</p>

    <div class="card mt-4">
        <div class="card-header">Add message</div>
        <div class="card-body text-start">
            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                <label class="form-label" for="FullName">Full name</label>
                    <input class="form-control" name="FullName" id="FullName" required maxlength="200" />

                </div>

                <div class="mb-3">
                    <label class="form-label" for="Email">Email</label>
                    <input class="form-control" name="Email" id="Email" type="email" required maxlength="200" />
                </div>


                <div class="mb-3">
                    <label class="form-label" for="Message">Message</label>
                    <textarea class="form-control" name="Message" id="Message" required maxlength="200"></textarea>
                </div>


                <button class="btn btn-primary" type="submit">Save</button>
            </form>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">Latest messages</div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Full name</th>
                            <th>Email</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var item = Model[i];
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                            <tr>
                                <td colspan="4" class="text-muted">@item.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No messages yet.</p>
            }
        </div>
    </div>
</div>

